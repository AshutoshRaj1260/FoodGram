# ==============================================================
# FoodGram Backend Environment Variables Example
# ==============================================================
# Contributors: Copy this file to '.env' and fill in your values.
# If you are not working on a specific feature (like Google OAuth
# or Image Uploads), you can often use dummy string values to 
# bypass startup errors, though those specific features will fail.

# JSON Web Token Secret Keys (Make up random strings for local dev)
# Access Token Secret (expires in 15m)
JWT_SECRET=super_secret_local_dev_key
# Refresh Token Secret (expires in 7d)
JWT_REFRESH_SECRET=super_secret_local_refresh_key

# MongoDB Connection URI (Atlas connection string recommended)
# Get a free cluster at: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb://localhost:27017/foodgram

# Server Port
PORT=3000

# ImageKit Credentials (for video/image storage)
# Get free keys at: https://imagekit.io/ dashboard under "Developer Options"
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id/

# Frontend URL (Used for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Google OAuth Credentials
# Get credentials at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
TRUST_PROXY=false
