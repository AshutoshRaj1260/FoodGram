# ==============================================================
# FoodGram Frontend Environment Variables Example
# ==============================================================
# Contributors: Copy this file to '.env' and fill in your values.
# Vite automatically loads environment variables prefixed with VITE_

# The base URL for the backend API
# If running the backend locally on port 3000:
VITE_API_URL=http://localhost:3000

# The URL for Google Authentication redirect
# This should point to your backend's OAuth trigger route
VITE_GOOGLE_AUTH_URL=http://localhost:3000/api/auth/google