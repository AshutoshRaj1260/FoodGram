# ==========================================
# FoodGram Environment Variables Example
# ==========================================
# CONTRIBUTOR NOTICE: 
# This file lists all possible environment variables for the project.
#
# As a contributor, please use local split-server development. You should
# copy the necessary variables into backend/.env and frontend/.env respectively. 
# You DO NOT need to configure a single-domain deployment (like Render)
# or deal with production hosting, as that is only for the project administrator.
#
# NOTE: If you are an open-source contributor and don't need to test
# certain features (like Google Auth or Video Uploads), you can use
# dummy values instead of real keys to bypass server crash errors.

# ------------------------------------------
# BACKEND (.env)
# ------------------------------------------
PORT=3000

# MongoDB Connection URI (Get a free cluster at MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/foodgram

# JWT Authentication (Any random string works locally)
JWT_SECRET=super_secret_local_dev_key

# Frontend URL (Used for CORS in split-domain dev)
FRONTEND_URL=http://localhost:5173

# ImageKit Configuration (Get free keys at ImageKit.io for testing uploads)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id/

# Google OAuth Credentials (Get from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback


# ------------------------------------------
# FRONTEND (.env) -> handled by Vite
# ------------------------------------------
# The base URL for the backend API
VITE_API_URL=http://localhost:3000

# The URL for Google Authentication redirect
VITE_GOOGLE_AUTH_URL=http://localhost:3000/api/auth/google
